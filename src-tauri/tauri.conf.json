{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "SimpleClock",
    "version": "1.0.1",
    "identifier": "com.simpleclock.widget",
    "build": {
        "frontendDist": "../ui"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "title": "SimpleClock",
                "width": 340,
                "height": 420,
                "resizable": false,
                "decorations": false,
                "transparent": false,
                "shadow": true,
                "backgroundColor": [
                    20,
                    20,
                    24,
                    255
                ],
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}